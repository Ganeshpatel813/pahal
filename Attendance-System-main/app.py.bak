@app.route("/api/colleges")
def get_colleges():
    db = get_db()
    colleges = db.execute("SELECT * FROM colleges ORDER BY name").fetchall()
    result = []
    for c in colleges:
        programs = db.execute(
            "SELECT p.*, (SELECT COUNT(*) FROM faculty f WHERE f.program_id=p.id AND f.role='faculty' AND f.is_active=1) as student_count "
            "FROM programs p WHERE p.college_id=? ORDER BY p.name", [c["id"]]
        ).fetchall()
        d = dict(c)
        d["programs"] = [dict(p) for p in programs]
        result.append(d)
    db.close()
    return jsonify(result)


