# â”€â”€ FILTERED ATTENDANCE API â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

@app.route("/api/admin/attendance/filtered")
@admin_required
def admin_attendance_filtered():
    args       = request.args
    college_id = args.get("collegeId", "")
    program_id = args.get("programId", "")
    faculty_id = args.get("facultyId", "")
    designation= args.get("designation", "")
    search     = args.get("search", "").strip()
    date_from  = args.get("from", "")
    date_to    = args.get("to", "")
    month      = args.get("month", "")
    mode       = args.get("mode", "detail")   # detail | summary

    db = get_db()

    if mode == "summary":
        # Per-faculty attendance % summary
        today_str = ist_today()
        if month:
            yr, mo = map(int, month.split("-"))
            _, dim = calendar.monthrange(yr, mo)
            wdays = sum(
                1 for d in range(1, dim + 1)
                if date(yr, mo, d).weekday() != 6
                and f"{yr}-{mo:02d}-{d:02d}" <= today_str
            )
            date_cond = f"strftime('%Y-%m',a.attendance_date)='{month}'"
        elif date_from and date_to:
            d1 = datetime.strptime(date_from, "%Y-%m-%d").date()
            d2 = datetime.strptime(date_to,   "%Y-%m-%d").date()
            wdays = sum(1 for i in range((d2 - d1).days + 1)
                        if (d1 + timedelta(days=i)).weekday() != 6)
            date_cond = f"a.attendance_date>='{date_from}' AND a.attendance_date<='{date_to}'"
        else:
            today = ist_today()
            wdays = 1 if date.fromisoformat(today).weekday() != 6 else 0
            date_cond = f"a.attendance_date='{today}'"

        fq = "SELECT f.id, f.name, f.employee_id, f.department, f.designation, f.college_id, f.program_id, f.face_image_path FROM faculty f WHERE f.role='faculty' AND f.is_active=1"
        fp = []
        if college_id: fq += " AND f.college_id=?";  fp.append(college_id)
        if program_id: fq += " AND f.program_id=?";  fp.append(program_id)
        if faculty_id: fq += " AND f.id=?";          fp.append(faculty_id)
        if designation:fq += " AND f.designation=?"; fp.append(designation)
        if search:     fq += " AND (f.name LIKE ? OR f.employee_id LIKE ?)"; fp += [f"%{search}%", f"%{search}%"]
        flist = db.execute(fq, fp).fetchall()

        result = []
        for f in flist:
            rows = db.execute(
                f"SELECT status, COUNT(*) as cnt FROM attendance a WHERE a.faculty_id=? AND {date_cond} GROUP BY status",
                [f["id"]]
            ).fetchall()
            stat = {"present": 0, "half_day": 0}
            for r in rows: stat[r["status"]] = r["cnt"]
            stat["absent"] = max(0, wdays - stat["present"] - stat["half_day"])
            stat["working_days"] = wdays
            pct = round(((stat["present"] + stat["half_day"] * 0.5) / wdays * 100), 1) if wdays else 0

            college = db.execute("SELECT name, short_name FROM colleges WHERE id=?", [f["college_id"]]).fetchone() if f["college_id"] else None
            program = db.execute("SELECT name FROM programs WHERE id=?", [f["program_id"]]).fetchone() if f["program_id"] else None
            result.append({
                "id": f["id"], "name": f["name"], "employeeId": f["employee_id"],
                "department": f["department"], "designation": f["designation"],
                "college": college["short_name"] if college else "â€”",
                "program": program["name"] if program else "â€”",
                "faceImagePath": f["face_image_path"],
                **stat, "attendancePct": pct, "workingDays": wdays
            })
        db.close()
        return jsonify({"mode": "summary", "workingDays": wdays, "faculty": result})

    # detail mode â€” raw attendance rows
    q = """SELECT a.*, f.name, f.employee_id, f.department, f.designation,
                  f.face_image_path, f.college_id, f.program_id
           FROM attendance a JOIN faculty f ON a.faculty_id=f.id WHERE 1=1"""
    p = []
    if college_id: q += " AND f.college_id=?";  p.append(college_id)
    if program_id: q += " AND f.program_id=?";  p.append(program_id)
    if faculty_id: q += " AND a.faculty_id=?";  p.append(faculty_id)
    if designation:q += " AND f.designation=?"; p.append(designation)
    if search:     q += " AND (f.name LIKE ? OR f.employee_id LIKE ?)"; p += [f"%{search}%", f"%{search}%"]
    if month:      q += " AND strftime('%Y-%m',a.attendance_date)=?"; p.append(month)
    elif date_from and date_to:
        q += " AND a.attendance_date>=? AND a.attendance_date<=?"; p += [date_from, date_to]
    else:
        q += " AND a.attendance_date=?"; p.append(ist_today())
    q += " ORDER BY a.attendance_date DESC, f.name ASC"

    rows = db.execute(q, p).fetchall()
    result = []
    for r in rows:
        row = dict(r)
        college = db.execute("SELECT short_name FROM colleges WHERE id=?", [row["college_id"]]).fetchone() if row.get("college_id") else None
        program = db.execute("SELECT name FROM programs WHERE id=?", [row["program_id"]]).fetchone() if row.get("program_id") else None
        row["college"] = college["short_name"] if college else "â€”"
        row["program"] = program["name"] if program else "â€”"
        result.append(row)
    db.close()
    return jsonify({"mode": "detail", "records": result})


if __name__ == "__main__":
    init_db()
    app.run(debug=True, host="0.0.0.0", port=5000)
